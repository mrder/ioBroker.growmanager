{
  "type": "tabs",
  "items": {
    "tabGeneral": {
      "type": "tab",
      "label": "Allgemein",
      "items": {
        "language": {
          "type": "select",
          "label": "Sprache",
          "options": [
            { "label": "Deutsch", "value": "de" },
            { "label": "English", "value": "en" }
          ],
          "default": "de"
        },
        "controlCycleSeconds": {
          "type": "number",
          "label": "Regelzyklus (Sekunden)",
          "min": 1,
          "max": 300,
          "default": 10,
          "help": "Wie oft der Adapter die Gruppen überprüft und Aktoren schaltet"
        },
        "startBehavior": {
          "type": "select",
          "label": "Verhalten beim Adapter-Start",
          "options": [
            { "label": "Letzten Zustand übernehmen", "value": "lastState" },
            { "label": "Automatik verzögert starten", "value": "delayedStart" },
            { "label": "Alle Aktoren sicher ausschalten", "value": "safeTurnOff" },
            { "label": "Nur überwachen", "value": "monitorOnly" }
          ],
          "default": "lastState"
        },
        "logLevel": {
          "type": "select",
          "label": "Log-Level",
          "options": [
            { "label": "Debug (sehr ausführlich)", "value": "debug" },
            { "label": "Info (empfohlen)", "value": "info" },
            { "label": "Warnung", "value": "warn" },
            { "label": "Fehler", "value": "error" }
          ],
          "default": "info"
        },
        "eventRetentionDays": {
          "type": "number",
          "label": "Alarm-Aufbewahrung (Tage)",
          "min": 1,
          "max": 365,
          "default": 30
        }
      }
    },
    "tabDashboard": {
      "type": "tab",
      "label": "Live-Dashboard",
      "items": {
        "_dashboardInfo": {
          "type": "staticText",
          "text": "Das Live-Dashboard ist nach dem Adapter-Start erreichbar unter: http://<ioBroker-IP>:<Port>/",
          "label": ""
        },
        "webPort": {
          "type": "number",
          "label": "Web-Port",
          "min": 1024,
          "max": 65535,
          "default": 8097,
          "help": "Port des integrierten Live-Dashboards (Standard: 8097)"
        },
        "webBindAddress": {
          "type": "text",
          "label": "Bind-Adresse",
          "default": "0.0.0.0",
          "help": "0.0.0.0 = alle Netzwerkschnittstellen, 127.0.0.1 = nur lokal"
        },
        "webAuth": {
          "type": "checkbox",
          "label": "Passwortschutz für Dashboard",
          "default": false
        }
      }
    },
    "tabGroups": {
      "type": "tab",
      "label": "Gruppen",
      "items": {
        "_groupsInfo": {
          "type": "staticText",
          "label": "",
          "text": "Gruppen werden als JSON konfiguriert. Klicke auf den Tab 'JSON' oben rechts im Admin-Dialog, um die Konfiguration direkt zu bearbeiten. Eine Beispiel-Gruppe findest du in der README.md."
        },
        "_groupsHint": {
          "type": "staticText",
          "label": "",
          "text": "Nach dem Start des Adapters ist das Live-Dashboard unter http://<IP>:8097/ erreichbar und zeigt alle konfigurierten Gruppen in Echtzeit."
        }
      }
    },
    "tabAlarms": {
      "type": "tab",
      "label": "Alarmkanäle",
      "items": {
        "_alarmInfo": {
          "type": "staticText",
          "label": "",
          "text": "Alarmkanäle (z.B. Pushover, Telegram) werden über den JSON-Editor konfiguriert. Alarme sind auch im Live-Dashboard und im ioBroker-Objektbaum unter growmanager.X.alarms sichtbar."
        }
      }
    }
  }
}
