{
  "common": {
    "name": "growmanager",
    "version": "0.1.10",
    "news": {
      "0.1.10": {
        "en": "Fix crash when opening group editor with missing climateProfiles in saved config",
        "de": "Absturz beim Öffnen des Gruppen-Editors behoben wenn climateProfiles in gespeicherter Config fehlt"
      },
      "0.1.9": {
        "en": "Fix build: reset index.html to TypeScript source entry; previous builds repackaged old bundle",
        "de": "Build-Fehler behoben: index.html auf TypeScript-Quelle zurückgesetzt; vorherige Builds hatten altes Bundle neu verpackt"
      },
      "0.1.8": {
        "en": "Robust socket bridge: check window.io immediately + polling fallback if onload does not fire",
        "de": "Robuste Socket-Bridge: window.io sofort prüfen + Polling-Fallback falls onload ausbleibt"
      },
      "0.1.7": {
        "en": "Fix ioBroker WebSockets v3 API (io.connect instead of io())",
        "de": "ioBroker WebSockets v3 API korrigiert (io.connect statt io())"
      },
      "0.1.4": {
        "en": "Fix save and socket connection",
        "de": "Speichern und Socket-Verbindung repariert"
      },
      "0.1.3": {
        "en": "Object picker, profile editor, save feedback",
        "de": "Objektbaum-Picker, Klimaprofile, Speicher-Feedback"
      },
      "0.1.2": {
        "en": "Fix admin UI loading",
        "de": "Admin UI Ladefehler behoben"
      },
      "0.1.1": {
        "en": "Initial release",
        "de": "Erste Version"
      }
    },
    "title": "GrowManager",
    "titleLang": {
      "en": "GrowManager",
      "de": "GrowManager"
    },
    "desc": {
      "en": "Modular adapter for monitoring and controlling grow tents, rooms and irrigation zones.",
      "de": "Modularer Adapter zur Überwachung und Regelung von Growzelten, Räumen und Bewässerungszonen."
    },
    "authors": [
      "mrder <mrder@hotmail.de>"
    ],
    "keywords": [
      "grow",
      "climate",
      "vpd",
      "humidity",
      "temperature",
      "irrigation"
    ],
    "license": "MIT",
    "platform": "Javascript/Node.js",
    "main": "build/main.js",
    "icon": "admin/growmanager.png",
    "enabled": true,
    "extIcon": "https://raw.githubusercontent.com/mrder/ioBroker.growmanager/main/admin/growmanager.png",
    "readme": "https://github.com/mrder/ioBroker.growmanager/blob/main/README.md",
    "loglevel": "info",
    "mode": "daemon",
    "type": "general",
    "singleton": false,
    "allowInit": true,
    "connectionType": "local",
    "dataSource": "push",
    "dependencies": [
      {
        "js-controller": ">=4.0.0"
      }
    ],
    "globalDependencies": [
      {
        "admin": ">=6.0.0"
      }
    ],
    "tier": 3,
    "adminUI": {
      "config": "html"
    }
  },
  "native": {
    "language": "de",
    "sampleInterval": 10,
    "controlCycleSeconds": 10,
    "maxConcurrentSwitches": 5,
    "maintenanceMode": false,
    "startBehavior": "lastState",
    "logLevel": "info",
    "eventRetentionDays": 30,
    "webPort": 8097,
    "webBindAddress": "0.0.0.0",
    "webAuth": false,
    "groups": [],
    "climateProfiles": [],
    "alarmChannels": []
  },
  "objects": [],
  "instanceObjects": [
    {
      "_id": "info",
      "type": "channel",
      "common": {
        "name": {
          "en": "Information",
          "de": "Information"
        }
      },
      "native": {}
    },
    {
      "_id": "info.connection",
      "type": "state",
      "common": {
        "name": {
          "en": "Connection state",
          "de": "Verbindungsstatus"
        },
        "type": "boolean",
        "role": "indicator.connected",
        "read": true,
        "write": false,
        "def": false
      },
      "native": {}
    },
    {
      "_id": "info.status",
      "type": "state",
      "common": {
        "name": {
          "en": "Adapter status",
          "de": "Adapter-Status"
        },
        "type": "string",
        "role": "text",
        "read": true,
        "write": false,
        "def": "starting"
      },
      "native": {}
    },
    {
      "_id": "info.version",
      "type": "state",
      "common": {
        "name": {
          "en": "Adapter version",
          "de": "Adapter-Version"
        },
        "type": "string",
        "role": "text",
        "read": true,
        "write": false,
        "def": ""
      },
      "native": {}
    },
    {
      "_id": "info.lastCycle",
      "type": "state",
      "common": {
        "name": {
          "en": "Last cycle timestamp",
          "de": "Letzter Zyklus"
        },
        "type": "number",
        "role": "value.time",
        "read": true,
        "write": false,
        "def": 0
      },
      "native": {}
    },
    {
      "_id": "info.activeAlarms",
      "type": "state",
      "common": {
        "name": {
          "en": "Active alarms",
          "de": "Aktive Alarme"
        },
        "type": "number",
        "role": "value",
        "read": true,
        "write": false,
        "def": 0
      },
      "native": {}
    },
    {
      "_id": "control",
      "type": "channel",
      "common": {
        "name": {
          "en": "Control",
          "de": "Steuerung"
        }
      },
      "native": {}
    },
    {
      "_id": "control.enabled",
      "type": "state",
      "common": {
        "name": {
          "en": "Adapter enabled",
          "de": "Adapter aktiv"
        },
        "type": "boolean",
        "role": "switch",
        "read": true,
        "write": true,
        "def": true
      },
      "native": {}
    },
    {
      "_id": "control.maintenance",
      "type": "state",
      "common": {
        "name": {
          "en": "Maintenance mode",
          "de": "Wartungsmodus"
        },
        "type": "boolean",
        "role": "switch",
        "read": true,
        "write": true,
        "def": false
      },
      "native": {}
    },
    {
      "_id": "control.emergencyStop",
      "type": "state",
      "common": {
        "name": {
          "en": "Emergency stop",
          "de": "Not-Aus"
        },
        "type": "boolean",
        "role": "switch",
        "read": true,
        "write": true,
        "def": false
      },
      "native": {}
    },
    {
      "_id": "control.acknowledgeAll",
      "type": "state",
      "common": {
        "name": {
          "en": "Acknowledge all alarms",
          "de": "Alle Alarme quittieren"
        },
        "type": "boolean",
        "role": "button",
        "read": false,
        "write": true,
        "def": false
      },
      "native": {}
    }
  ]
}