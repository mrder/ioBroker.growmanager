{
  "common": {
    "name": "growmanager",
    "version": "0.1.0",
    "news": {
      "0.1.0": {
        "en": "Initial release: full implementation of phases 1-11, optional sensors/actuators, live dashboard, VPD/temperature/humidity/irrigation control, shared actuators, 4-level diagnostics",
        "de": "Erste Version: vollständige Implementierung der Phasen 1–11, optionale Sensorik/Aktorik, Live-Dashboard, VPD/Temperatur/Feuchte/Bewässerungsregelung, geteilte Aktoren, 4-Ebenen-Diagnose"
      }
    },
    "title": "GrowManager",
    "titleLang": {
      "en": "GrowManager",
      "de": "GrowManager"
    },
    "desc": {
      "en": "Modular adapter for monitoring and controlling grow tents, rooms and irrigation zones. Supports VPD, temperature, humidity and irrigation control with optional sensors and actuators.",
      "de": "Modularer Adapter zur Überwachung und Regelung von Growzelten, Räumen und Bewässerungszonen. Unterstützt VPD-, Temperatur-, Feuchte- und Bewässerungsregelung mit optionaler Sensorik und Aktorik."
    },
    "authors": [
      "GrowManager Contributors"
    ],
    "keywords": [
      "grow",
      "growroom",
      "growtent",
      "climate",
      "vpd",
      "humidity",
      "temperature",
      "irrigation",
      "plant",
      "cannabis",
      "hydroponics"
    ],
    "license": "MIT",
    "platform": "Javascript/Node.js",
    "main": "build/main.js",
    "icon": "admin/growmanager.png",
    "enabled": true,
    "extIcon": "https://raw.githubusercontent.com/iobroker-community/ioBroker.growmanager/main/admin/growmanager.png",
    "readme": "https://github.com/iobroker-community/ioBroker.growmanager/blob/main/README.md",
    "loglevel": "info",
    "mode": "daemon",
    "type": "garden",
    "category": "garden",
    "singleton": false,
    "allowInit": true,
    "connectionType": "local",
    "dataSource": "push",
    "compact": true,
    "supportCustoms": false,
    "visWidgets": {},
    "adminUI": {
      "config": "json"
    },
    "dependencies": [
      {
        "js-controller": ">=4.0.0"
      }
    ],
    "globalDependencies": [
      {
        "admin": ">=6.0.0"
      }
    ],
    "tier": 3,
    "plugins": {
      "webservers": {
        "8097": {
          "description": {
            "en": "GrowManager Live Dashboard",
            "de": "GrowManager Live-Dashboard"
          }
        }
      }
    }
  },
  "native": {
    "language": "de",
    "sampleInterval": 10,
    "controlCycleSeconds": 10,
    "maxConcurrentSwitches": 5,
    "maintenanceMode": false,
    "startBehavior": "lastState",
    "logLevel": "info",
    "eventRetentionDays": 30,
    "webPort": 8097,
    "webBindAddress": "0.0.0.0",
    "webAuth": false,
    "groups": [],
    "alarmChannels": []
  },
  "objects": [],
  "instanceObjects": [
    {
      "_id": "info",
      "type": "channel",
      "common": {
        "name": {
          "en": "Information",
          "de": "Information"
        }
      },
      "native": {}
    },
    {
      "_id": "info.connection",
      "type": "state",
      "common": {
        "name": {
          "en": "Connection state",
          "de": "Verbindungsstatus"
        },
        "type": "boolean",
        "role": "indicator.connected",
        "read": true,
        "write": false,
        "def": false
      },
      "native": {}
    },
    {
      "_id": "info.status",
      "type": "state",
      "common": {
        "name": {
          "en": "Adapter status",
          "de": "Adapter-Status"
        },
        "type": "string",
        "role": "text",
        "read": true,
        "write": false,
        "def": "starting"
      },
      "native": {}
    },
    {
      "_id": "info.version",
      "type": "state",
      "common": {
        "name": {
          "en": "Adapter version",
          "de": "Adapter-Version"
        },
        "type": "string",
        "role": "text",
        "read": true,
        "write": false,
        "def": ""
      },
      "native": {}
    },
    {
      "_id": "info.lastCycle",
      "type": "state",
      "common": {
        "name": {
          "en": "Last control cycle timestamp",
          "de": "Zeitstempel des letzten Regelzyklus"
        },
        "type": "number",
        "role": "value.time",
        "read": true,
        "write": false,
        "def": 0
      },
      "native": {}
    },
    {
      "_id": "info.activeAlarms",
      "type": "state",
      "common": {
        "name": {
          "en": "Number of active alarms",
          "de": "Anzahl aktiver Alarme"
        },
        "type": "number",
        "role": "value",
        "read": true,
        "write": false,
        "def": 0
      },
      "native": {}
    },
    {
      "_id": "control",
      "type": "channel",
      "common": {
        "name": {
          "en": "Control",
          "de": "Steuerung"
        }
      },
      "native": {}
    },
    {
      "_id": "control.enabled",
      "type": "state",
      "common": {
        "name": {
          "en": "Adapter enabled",
          "de": "Adapter aktiv"
        },
        "type": "boolean",
        "role": "switch",
        "read": true,
        "write": true,
        "def": true
      },
      "native": {}
    },
    {
      "_id": "control.maintenance",
      "type": "state",
      "common": {
        "name": {
          "en": "Global maintenance mode",
          "de": "Globaler Wartungsmodus"
        },
        "type": "boolean",
        "role": "switch",
        "read": true,
        "write": true,
        "def": false
      },
      "native": {}
    },
    {
      "_id": "control.emergencyStop",
      "type": "state",
      "common": {
        "name": {
          "en": "Emergency stop – all actuators to safe state",
          "de": "Not-Aus – alle Aktoren in sicheren Zustand"
        },
        "type": "boolean",
        "role": "switch",
        "read": true,
        "write": true,
        "def": false
      },
      "native": {}
    },
    {
      "_id": "control.acknowledgeAll",
      "type": "state",
      "common": {
        "name": {
          "en": "Acknowledge all alarms",
          "de": "Alle Alarme quittieren"
        },
        "type": "boolean",
        "role": "button",
        "read": false,
        "write": true,
        "def": false
      },
      "native": {}
    }
  ]
}
